   "source": [
    "Die **Generatoren** in ${\\mathbb{Z}}_{17}^{\\ast}$ berechnen:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "f2033ba8-fbe9-4442-96e0-7d55123e00b9",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "{3, 5, 6, 7, 10, 11, 12, 14}\n"
     ]
    }
   ],
   "source": [
    "modul = 17\n",
    "generatoren = set()\n",
    "for i in range(2,modul):\n",
    "    potenzen = set()\n",
    "    for k in range(1,modul):\n",
    "        potenzen.add((i**k)%17)\n",
    "    if len(potenzen) == 16:\n",
    "        generatoren.add(i)\n",
    "\n",
    "print(generatoren)"
   ]
  }
 ],
